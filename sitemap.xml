assignment:
  name: "PoE Part 2 - Designing the Visuals"
  total_points: 100
  pass_mark: 50

criteria:
  - id: structure
    title: "Project structure & file organisation"
    points: 10
    checks:
      - type: "exists"
        points: 2
        description: "Root index.html exists"
        path: "index.html"

      - type: "exists"
        points: 2
        description: "CSS folder and main stylesheet exists"
        path: "css/style.css"

      - type: "exists"
        points: 2
        description: "Assets folder exists"
        path: "assets"

      - type: "exists"
        points: 2
        description: "README.md exists"
        path: "README.md"

      - type: "glob_min_count"
        points: 2
        description: "At least 2 HTML pages exist (index + another page)"
        pattern: "*.html"
        min_count: 2

  - id: css_styling
    title: "CSS styling (layout, typography, colour scheme)"
    points: 25
    checks:
      - type: "html_contains"
        points: 6
        description: "HTML pages link to css/style.css"
        files_glob: "*.html"
        must_contain_regex: "<link[^>]+href=[\"']css/style\\.css[\"']"
        mode: "all"

      - type: "css_min_rules"
        points: 5
        description: "CSS has enough rules to reflect styling effort"
        path: "css/style.css"
        min_rules: 20

      - type: "css_contains_any"
        points: 7
        description: "Typography applied (font-family/line-height/font-size)"
        path: "css/style.css"
        any_of:
          - "font-family"
          - "line-height"
          - "font-size"

      - type: "css_contains_any"
        points: 7
        description: "Colour scheme applied (color/background-color variables allowed)"
        path: "css/style.css"
        any_of:
          - "color"
          - "background"
          - "background-color"
          - "--"

  - id: responsiveness
    title: "Responsive design (mobile/tablet/desktop)"
    points: 25
    checks:
      - type: "html_contains"
        points: 5
        description: "Viewport meta tag present"
        files_glob: "*.html"
        must_contain_regex: "<meta[^>]+name=[\"']viewport[\"'][^>]+>"
        mode: "all"

      - type: "css_contains_regex"
        points: 10
        description: "Uses media queries for responsiveness"
        path: "css/style.css"
        regex: "@media\\s*\\("

      - type: "css_contains_any"
        points: 5
        description: "Uses responsive units (%, rem, vw/vh, flex, grid)"
        path: "css/style.css"
        any_of:
          - "display: flex"
          - "display:flex"
          - "display: grid"
          - "display:grid"
          - "rem"
          - "vw"
          - "vh"
          - "%"

      - type: "glob_min_count"
        points: 5
        description: "Responsive evidence screenshots included"
        pattern: "assets/screenshots/*"
        min_count: 3

  - id: ux_accessibility
    title: "User experience & accessibility basics"
    points: 20
    checks:
      - type: "html_contains"
        points: 4
        description: "Semantic structure used (header/nav/main/footer)"
        files_glob: "*.html"
        must_contain_all:
          - "<header"
          - "<nav"
          - "<main"
          - "<footer"
        mode: "all"

      - type: "html_img_alt_ratio"
        points: 6
        description: "Most images include alt text"
        files_glob: "*.html"
        min_ratio: 0.8

      - type: "css_contains_any"
        points: 5
        description: "Focusable/interactive elements styled (hover/focus)"
        path: "css/style.css"
        any_of:
          - ":hover"
          - ":focus"
          - ":focus-visible"

      - type: "html_nav_consistency"
        points: 5
        description: "Navigation is consistent across pages (same links/labels)"
        files_glob: "*.html"
        nav_selector: "nav"
        require_same_order: false
        compare: "text_and_href"

  - id: documentation
    title: "README documentation, changelog & references"
    points: 10
    checks:
      - type: "readme_contains_headings"
        points: 4
        description: "README includes Part 2 section + Responsive Evidence"
        path: "README.md"
        headings:
          - "Part 2"
          - "Responsive Evidence"

      - type: "readme_contains_headings"
        points: 3
        description: "README includes Changelog + References (Harvard)"
        path: "README.md"
        headings:
          - "Changelog"
          - "References"

      - type: "readme_min_reference_count"
        points: 3
        description: "At least 3 references listed (images/fonts/code/inspiration)"
        path: "README.md"
        min_count: 3

  - id: version_control
    title: "Version control practice (meaningful commits)"
    points: 10
    checks:
      - type: "git_min_commits"
        points: 5
        description: "At least 5 commits exist"
        min_commits: 5

      - type: "git_commit_message_regex_count"
        points: 5
        description: "At least 3 commits use Part2: prefix"
        regex: "^Part2:"
        min_count: 3